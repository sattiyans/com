---
import { getCollection } from "astro:content";
import { SITE, SOCIALS } from "@consts";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.password)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

function normalizeProjectImagePath(path: string): string {
  if (path.startsWith("http://") || path.startsWith("https://")) return path;
  if (path.startsWith("/")) return path;
  return `/projects/${path}`;
}

function getProjectImage(project: (typeof projects)[number]): string {
  if (project.data.screenshots?.length) return normalizeProjectImagePath(project.data.screenshots[0]);
  if (project.data.featuredImage) return normalizeProjectImagePath(project.data.featuredImage);
  return "/og-image.png";
}

function getProjectImages(project: (typeof projects)[number]): string[] {
  const images = (project.data.screenshots || []).map((image) => normalizeProjectImagePath(image));
  if (images.length > 0) return images;
  return [getProjectImage(project)];
}

function getProjectResults(project: (typeof projects)[number]): string[] {
  const raw = project.data.results;
  if (Array.isArray(raw)) return raw;
  if (raw) return [raw];
  return ["Delivered and deployed a production-ready version aligned to project goals."];
}

function toDisplayDomain(url?: string): string {
  if (!url) return "Private or unavailable";
  try {
    const parsed = new URL(url);
    const host = parsed.hostname.replace(/^www\./i, "");
    return `www.${host}`;
  } catch {
    const cleaned = url.replace(/^https?:\/\//i, "").split("/")[0].replace(/^www\./i, "");
    return cleaned ? `www.${cleaned}` : "Private or unavailable";
  }
}

function toDisplayLink(url?: string): string {
  if (!url) return "N/A";
  try {
    const parsed = new URL(url);
    const host = parsed.hostname.replace(/^www\./i, "");
    const path = parsed.pathname.replace(/\/$/, "");
    return `${host}${path}`;
  } catch {
    return url.replace(/^https?:\/\//i, "").replace(/^www\./i, "").replace(/\/$/, "");
  }
}

function toSentenceFragment(text: string, max = 175): string {
  const normalized = text.replace(/\s+/g, " ").trim();
  if (!normalized) return "";
  const [firstSentence] = normalized.split(/(?<=[.!?])\s+/);
  let fragment = (firstSentence || normalized).trim();
  if (fragment.length > max) {
    fragment = fragment.slice(0, max);
    const lastSpace = fragment.lastIndexOf(" ");
    if (lastSpace > 0) fragment = fragment.slice(0, lastSpace);
  }
  return fragment.replace(/[.,;:!?-]+$/g, "").trim();
}

function lowerFirst(text: string): string {
  if (!text) return "";
  return text.charAt(0).toLowerCase() + text.slice(1);
}

function summarizeProblemText(text: string): string {
  const fragment = toSentenceFragment(text, 170);
  if (!fragment) return "Addressed a core product and operational gap for users.";
  const cleaned = fragment.replace(/^(the problem was|problem:)\s+/i, "").trim();
  return `Addressed ${lowerFirst(cleaned)}.`;
}

function summarizeSolutionText(text: string): string {
  const fragment = toSentenceFragment(text, 175);
  if (!fragment) return "Implemented a practical solution focused on scalability and reliability.";
  const cleaned = fragment
    .replace(/^(i\s+)?(built|developed|created|implemented|designed)\s+/i, "")
    .replace(/^(a|an|the)\s+/i, (match) => match.toLowerCase())
    .trim();
  return `Implemented ${lowerFirst(cleaned)}.`;
}

function getTechStackText(project: (typeof projects)[number]): string {
  const tech = project.data.techStack || [];
  if (!tech.length) return "Tech stack available on request.";
  return tech.slice(0, 10).join(", ");
}

const githubUrl = SOCIALS.find((social) => social.NAME === "GitHub")?.HREF;
const linkedinUrl = SOCIALS.find((social) => social.NAME === "LinkedIn")?.HREF;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{`Project Portfolio | ${SITE.NAME}`}</title>
    <meta name="description" content="Slide-style project portfolio for Sattiyan Selvarajah with one project per page." />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: radial-gradient(circle at 20% 0%, #11162a 0%, #06080f 50%, #04060c 100%);
        color: #f3f4f6;
        overflow: hidden;
      }

      .controls {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 20;
      }

      .download-btn,
      .arrow-btn {
        pointer-events: auto;
        position: fixed;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(9, 11, 20, 0.85);
        color: #f3f4f6;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        backdrop-filter: blur(6px);
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.35);
      }
      .download-btn {
        top: 0.95rem;
        right: 0.95rem;
        width: auto;
        height: auto;
        border: 0;
        background: transparent;
        box-shadow: none;
        padding: 0;
        color: #cbd5e1;
      }
      .download-btn:disabled,
      .download-btn.is-loading {
        cursor: progress;
        pointer-events: none;
        opacity: 0.7;
      }
      .download-btn:hover {
        color: #f8fafc;
        transform: translateY(-0.5px);
      }
      .download-btn:active {
        transform: translateY(0);
      }
      .download-btn .download-label {
        display: none;
      }
      .download-icon {
        display: inline-block;
      }
      .download-spinner {
        display: none;
        animation: spin 0.8s linear infinite;
      }
      .download-btn.is-loading .download-icon {
        display: none;
      }
      .download-btn.is-loading .download-spinner {
        display: inline-block;
      }
      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      .arrow-btn {
        width: 2.7rem;
        height: 2.7rem;
        border-radius: 9999px;
      }
      .arrow-btn { top: calc(50% - 1.35rem); }
      .arrow-left { left: 0.95rem; }
      .arrow-right { right: 0.95rem; }

      .slide-counter {
        position: fixed;
        bottom: 0.8rem;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.8rem;
        color: #9ca3af;
        z-index: 20;
      }

      .deck {
        width: 100vw;
        height: 100vh;
        overflow: hidden;
      }

      .slides-track {
        display: flex;
        width: 100%;
        height: 100%;
        transition: transform 320ms ease;
      }

      .slide-shell {
        width: 100vw;
        height: 100vh;
        flex: 0 0 100vw;
        padding: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .slide {
        width: min(1280px, 100%);
        height: min(700px, 100%);
        background: linear-gradient(180deg, rgba(15, 19, 31, 0.95), rgba(7, 10, 18, 0.95));
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        box-shadow: 0 22px 45px rgba(0, 0, 0, 0.45);
        padding: 1.35rem 1.4rem 1.8rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      .site-url {
        position: absolute;
        top: 0.68rem;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.8rem;
        color: #9ca3af;
        letter-spacing: 0.01em;
      }

      .intro-rich {
        justify-content: center;
        align-items: center;
      }

      .intro-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: min(900px, calc(100% - 2.8rem));
      }

      .intro-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        align-items: stretch;
        width: 100%;
      }

      .intro-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.7rem;
        align-items: center;
        text-align: center;
        max-width: 760px;
        margin: 0 auto;
      }

      .intro-eyebrow {
        color: #93c5fd;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .intro h1 { font-size: clamp(2.1rem, 4.7vw, 3.4rem); margin: 0; color: #fff; line-height: 1.05; }

      .intro-lead {
        margin: 0;
        font-size: 1rem;
        color: #dbe3ee;
        max-width: 52ch;
      }

      .intro-cv-link {
        margin: 0;
        font-size: 0.92rem;
        color: #cbd5e1;
      }
      .intro-cv-link a {
        color: #bfdbfe;
        text-decoration: none;
      }
      .intro-cv-link a:hover {
        color: #dbeafe;
        text-decoration: underline;
      }

      .intro-tech {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      .intro-tech span {
        border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 9999px;
        background: rgba(148, 163, 184, 0.12);
        color: #dbe3ee;
        padding: 0.2rem 0.55rem;
        font-size: 0.72rem;
      }

      .intro-card {
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 14px;
        background: linear-gradient(160deg, rgba(12, 18, 32, 0.9), rgba(2, 8, 23, 0.86));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
        padding: 0.75rem;
      }

      .terminal-head {
        display: flex;
        gap: 0.33rem;
        margin-bottom: 0.55rem;
      }

      .terminal-head span {
        width: 0.48rem;
        height: 0.48rem;
        border-radius: 999px;
        display: inline-block;
      }

      .terminal-head span:nth-child(1) { background: #fb7185; }
      .terminal-head span:nth-child(2) { background: #facc15; }
      .terminal-head span:nth-child(3) { background: #4ade80; }

      .terminal-lines {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        color: #e2e8f0;
      }

      .terminal-lines li {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 0.78rem;
        color: #cbd5e1;
      }

      .terminal-lines .prompt {
        color: #93c5fd;
      }

      .project-head {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.35rem;
        margin-bottom: 0.7rem;
      }
      .project-head h2 {
        margin: 0;
        font-size: clamp(1.35rem, 2.3vw, 2rem);
        color: #fff;
      }
      .project-head .meta {
        text-align: left;
        color: #94a3b8;
        font-size: 0.82rem;
        display: flex;
        align-items: center;
        gap: 0.55rem;
        flex-wrap: wrap;
      }

      .project-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.8rem;
      }

      .image-wrap {
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 14px;
        overflow: hidden;
        background: #0b1020;
        position: relative;
      }

      .media-stage {
        width: 100%;
        min-height: 100%;
        aspect-ratio: 16 / 9;
        display: block;
        padding: 0.45rem;
        background: radial-gradient(circle at 50% 30%, #0f172a, #020617);
      }

      .media-image {
        width: 100%;
        height: 100%;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 10px;
        background: #0b1020;
        object-fit: cover;
        display: block;
      }

      .info-grid {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }

      .simple-block {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 0.55rem;
      }

      .simple-block h3 {
        margin: 0 0 0.35rem;
        font-size: 0.72rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #93c5fd;
      }
      .simple-block p {
        margin: 0;
        font-size: 0.88rem;
        line-height: 1.35;
        color: #dbe3ee;
      }

      .outcomes {
        margin: 0;
        padding-left: 0;
        list-style: none;
        color: #dbe3ee;
      }
      .outcomes li {
        display: flex;
        align-items: flex-start;
        font-size: 0.85rem;
        line-height: 1.3;
        margin: 0.2rem 0;
      }
      .outcomes li::before {
        content: "•";
        color: #dbe3ee;
        margin-right: 0.45rem;
        line-height: 1.1;
      }

      .tech-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        align-items: center;
      }
      .tech-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(147, 197, 253, 0.35);
        background: rgba(30, 58, 138, 0.18);
        color: #bfdbfe;
        border-radius: 9999px;
        min-height: 1.42rem;
        padding: 0.2rem 0.55rem;
        font-size: 0.72rem;
        line-height: 1;
        white-space: nowrap;
      }

      .project-foot {
        position: absolute;
        left: 50%;
        bottom: 0.6rem;
        transform: translateX(-50%);
        font-size: 0.74rem;
        line-height: 1.2;
        color: #94a3b8;
        text-align: center;
        width: calc(100% - 2.4rem);
        white-space: normal;
        overflow-wrap: anywhere;
      }

      .contact-slide {
        justify-content: center;
      }

      .contact-wrap {
        width: min(860px, 100%);
        margin: 0 auto;
      }

      .contact-title {
        margin: 0;
        font-size: clamp(1.8rem, 3.2vw, 2.6rem);
        text-align: center;
        color: #fff;
      }

      .contact-sub {
        margin: 0.55rem auto 1rem;
        max-width: 54ch;
        text-align: center;
        color: #cbd5e1;
        font-size: 0.95rem;
      }

      .contact-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.68rem;
      }

      .contact-item {
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(15, 23, 42, 0.42);
        border-radius: 12px;
        padding: 0.72rem 0.78rem;
      }

      .contact-item .label {
        display: block;
        margin-bottom: 0.24rem;
        color: #93c5fd;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .contact-item .value {
        color: #e2e8f0;
        font-size: 0.92rem;
        word-break: break-word;
      }

      @media (max-width: 960px) {
        html, body { overflow: auto; }
        .deck { height: auto; overflow: visible; }
        .slides-track { display: block; height: auto; transform: none !important; transition: none; }
        .slide-shell { width: 100%; height: auto; padding: 0.8rem; }
        .slide { height: auto; min-height: auto; padding: 1rem; }
        .site-url { position: static; transform: none; margin-bottom: 0.65rem; text-align: center; }
        .intro-center { position: static; transform: none; width: 100%; }
        .intro-grid { grid-template-columns: 1fr; }
        .intro-points { grid-template-columns: 1fr; }
        .contact-grid { grid-template-columns: 1fr; }
        .project-foot {
          position: static;
          transform: none;
          width: 100%;
          margin-top: 0.55rem;
        }
        .project-layout { grid-template-columns: 1fr; }
        .info-grid { grid-template-columns: 1fr; }
        .project-head .meta { text-align: left; }
        .arrow-btn { display: none; }
        .slide-counter { display: none; }
      }

      @media print {
        @page { size: A4 landscape; margin: 8mm; }
        html, body {
          overflow: visible;
          background: #fff;
          color: #111827;
        }
        .controls, .slide-counter { display: none !important; }
        .deck { height: auto; overflow: visible; }
        .slides-track { display: block; transform: none !important; }
        .slide-shell {
          width: 100%;
          height: auto;
          padding: 0;
          display: block;
          break-after: page;
          page-break-after: always;
        }
        .slide-shell:last-child {
          break-after: auto;
          page-break-after: auto;
        }
        .slide {
          width: 100%;
          height: auto;
          background: #fff;
          color: #111827;
          border: 0;
          border-radius: 0;
          box-shadow: none;
          padding: 5mm;
        }
        .intro h1, .project-head h2 { color: #111827; }
        .intro p, .project-head .meta, .project-foot { color: #4b5563; }
        .card { background: #fff; border-color: rgba(17, 24, 39, 0.18); }
        .card p, .card ul { color: #1f2937; }
      }
    </style>
  </head>
  <body>
    <div class="controls" aria-hidden="false">
      <button type="button" id="download-pdf" class="download-btn" aria-label="Download PDF slides">
        <svg class="download-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3v11"></path>
          <path d="M8 10l4 4 4-4"></path>
          <path d="M4 17v3h16v-3"></path>
        </svg>
        <svg class="download-spinner" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12a9 9 0 1 1-2.64-6.36" stroke-linecap="round"></path>
        </svg>
        <span class="download-label">Download PDF (Slides)</span>
      </button>
      <button type="button" id="prev-slide" class="arrow-btn arrow-left" aria-label="Previous slide">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
      </button>
      <button type="button" id="next-slide" class="arrow-btn arrow-right" aria-label="Next slide">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M9 6l6 6-6 6"></path>
        </svg>
      </button>
    </div>

    <div id="slide-counter" class="slide-counter">1 / {projects.length + 2}</div>

    <main class="deck">
      <div id="slides-track" class="slides-track">
        <section class="slide-shell">
          <article class="slide intro intro-rich">
            <div class="intro-center">
              <div class="intro-grid">
                <div class="intro-left">
                  <span class="intro-eyebrow">Portfolio Deck</span>
                  <h1>{SITE.NAME}</h1>
                  <p class="intro-lead">
                    Selected software projects with delivery approach, tech stack, and outcomes.
                  </p>
                  <p class="intro-cv-link"><a href="/cv">www.sattiyans.com/cv</a></p>
                </div>
              </div>
            </div>
          </article>
        </section>

        {projects.map((project) => {
          return (
          <section class="slide-shell">
            <article class="slide">
              <div class="site-url">www.sattiyans.com</div>
              <div class="project-head">
                <div>
                  <h2>{project.data.title}</h2>
                  <p style="margin:0.25rem 0 0; color:#94a3b8;">{project.data.description}</p>
                  <div class="meta" style="margin-top:0.42rem;">
                    <span>{new Date(project.data.date).toLocaleDateString("en-US", { month: "short", year: "numeric" })}</span>
                    {project.data.role && <span>{project.data.role}</span>}
                  </div>
                </div>
              </div>

              <div class="project-layout">
                <div class="image-wrap">
                  <div class="media-stage">
                    <img
                      class="media-image"
                      src={getProjectImage(project)}
                      alt={`${project.data.title} screenshot`}
                      loading="eager"
                    />
                  </div>
                </div>

                <div class="info-grid">
                  <div class="simple-block">
                    <h3>Problem Solved</h3>
                    <p>{summarizeProblemText(project.data.problem || project.data.description)}</p>
                  </div>
                  <div class="simple-block">
                    <h3>How I Solved It</h3>
                    <p>{summarizeSolutionText(project.data.solution || project.data.description)}</p>
                  </div>
                  <div class="simple-block">
                    <h3>Tech Stack</h3>
                    <p>{getTechStackText(project)}</p>
                  </div>
                  <div class="simple-block" style="border-bottom:0; padding-bottom:0;">
                    <h3>Key Outcomes</h3>
                    <ul class="outcomes">
                      {getProjectResults(project).slice(0, 2).map((result) => (
                        <li>{result}</li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>

              <div class="project-foot">
                {`Project URL: ${toDisplayDomain(project.data.projectURL)}`}
              </div>
            </article>
          </section>
        )})}

        <section class="slide-shell">
          <article class="slide contact-slide">
            <div class="contact-wrap">
              <h2 class="contact-title">Let&apos;s Connect</h2>
              <p class="contact-sub">
                Open to software engineering roles, product development projects, and technical collaboration.
              </p>
              <div class="contact-grid">
                <div class="contact-item">
                  <span class="label">Website</span>
                  <span class="value">www.sattiyans.com</span>
                </div>
                <div class="contact-item">
                  <span class="label">Email</span>
                  <span class="value">{SITE.EMAIL}</span>
                </div>
                <div class="contact-item">
                  <span class="label">LinkedIn</span>
                  <span class="value">{toDisplayLink(linkedinUrl)}</span>
                </div>
                <div class="contact-item">
                  <span class="label">GitHub</span>
                  <span class="value">{toDisplayLink(githubUrl)}</span>
                </div>
              </div>
            </div>
          </article>
        </section>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <script is:inline>
      async function downloadSlidesAsPdf() {
        const downloadBtn = document.getElementById("download-pdf");
        if (!downloadBtn) return;

        const html2canvasLib = window.html2canvas;
        const jsPdfLib = window.jspdf?.jsPDF;
        if (!html2canvasLib || !jsPdfLib) {
          alert("PDF libraries failed to load. Please refresh and try again.");
          return;
        }

        const slides = Array.from(document.querySelectorAll(".slide-shell .slide"));
        if (!slides.length) return;

        downloadBtn.disabled = true;
        downloadBtn.classList.add("is-loading");
        downloadBtn.setAttribute("aria-busy", "true");

        const exportStage = document.createElement("div");
        exportStage.style.position = "fixed";
        exportStage.style.left = "-20000px";
        exportStage.style.top = "0";
        exportStage.style.width = "1280px";
        exportStage.style.height = "720px";
        exportStage.style.pointerEvents = "none";
        exportStage.style.overflow = "hidden";
        document.body.appendChild(exportStage);

        try {
          const pdf = new jsPdfLib({
            orientation: "landscape",
            unit: "px",
            format: [1280, 720]
          });

          for (let i = 0; i < slides.length; i += 1) {
            exportStage.innerHTML = "";
            const clone = slides[i].cloneNode(true);
            clone.style.width = "1280px";
            clone.style.height = "720px";
            clone.style.margin = "0";
            clone.style.maxWidth = "none";
            clone.style.maxHeight = "none";
            clone.style.borderRadius = "0";
            clone.style.boxShadow = "none";
            clone.style.transform = "none";
            exportStage.appendChild(clone);

            // Let browser paint before capture for reliable render.
            await new Promise((resolve) => requestAnimationFrame(() => resolve(true)));

            const canvas = await html2canvasLib(clone, {
              backgroundColor: "#050814",
              scale: 2,
              useCORS: true,
              logging: false
            });

            const imageData = canvas.toDataURL("image/jpeg", 0.96);
            if (i > 0) pdf.addPage([1280, 720], "landscape");
            pdf.addImage(imageData, "JPEG", 0, 0, 1280, 720);
          }

          pdf.save("sattiyan-portfolio-deck.pdf");
        } catch (error) {
          console.error("PDF generation failed:", error);
          alert("Failed to generate PDF. Please try again.");
        } finally {
          exportStage.remove();
          downloadBtn.disabled = false;
          downloadBtn.classList.remove("is-loading");
          downloadBtn.setAttribute("aria-busy", "false");
        }
      }

      const track = document.getElementById("slides-track");
      const prevBtn = document.getElementById("prev-slide");
      const nextBtn = document.getElementById("next-slide");
      const counter = document.getElementById("slide-counter");
      const totalSlides = track ? track.children.length : 0;
      let currentSlide = 0;

      function updateSlides() {
        if (!track) return;
        track.style.transform = `translateX(-${currentSlide * 100}vw)`;
        if (counter) counter.textContent = `${currentSlide + 1} / ${totalSlides}`;
      }

      function goToSlide(index) {
        currentSlide = Math.max(0, Math.min(totalSlides - 1, index));
        updateSlides();
      }

      prevBtn?.addEventListener("click", () => goToSlide(currentSlide - 1));
      nextBtn?.addEventListener("click", () => goToSlide(currentSlide + 1));
      document.getElementById("download-pdf")?.addEventListener("click", downloadSlidesAsPdf);

      window.addEventListener("keydown", (event) => {
        if (event.key === "ArrowRight") goToSlide(currentSlide + 1);
        if (event.key === "ArrowLeft") goToSlide(currentSlide - 1);
      });

      updateSlides();
    </script>
  </body>
</html>
