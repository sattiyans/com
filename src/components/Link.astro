---
import { cn } from "@lib/utils";

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
  class?: string;
  "aria-label"?: string;
}

const { href, external, underline = true, class: className, ...rest } = Astro.props;
---

<a 
  href={href} 
  target={ external ? "_blank" : "_self" } 
  class={cn(
    "transition-colors duration-300 ease-in-out",
    underline
      ? "inline-block underline underline-offset-2 decoration-black/15 dark:decoration-white/30 hover:decoration-black/25 hover:dark:decoration-white/50 text-current hover:text-black hover:dark:text-white"
      : "no-underline",
    className
  )}
  {...rest}>
  <slot/>
</a>
