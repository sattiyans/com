---
import { SITE } from "@consts";

const linkedinUrl = "https://www.linkedin.com/in/sattiyans";
---

<section class="not-prose animate">
  <div class="rounded-2xl border border-black/15 dark:border-white/15 bg-black/[0.015] dark:bg-white/[0.02] px-6 py-10 text-center sm:px-8 sm:py-12">
    <div class="mx-auto max-w-xl">
      <span class="inline-flex items-center gap-2 rounded-full border border-black/10 dark:border-white/15 bg-white dark:bg-white/5 px-3 py-1 text-xs font-medium text-gray-600 dark:text-gray-400">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500/60"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
        </span>
        Available for freelance &amp; collaborations
      </span>

      <h2 class="mt-5 text-2xl sm:text-3xl font-semibold tracking-tight text-black dark:text-white">
        Let's build something that ships.
      </h2>
      <p class="mt-3 mx-auto max-w-md text-sm sm:text-base leading-relaxed text-gray-600 dark:text-gray-400">
        SaaS platforms, GenAI automation, payment and API integrations — from
        architecture to production. Tell me what you're building.
      </p>

      <div class="mt-7 flex flex-wrap justify-center gap-2.5">
        <a
          href={`mailto:${SITE.EMAIL}`}
          class="inline-flex items-center gap-2 rounded-full bg-black dark:bg-white px-5 py-2.5 text-sm font-semibold text-white dark:text-black transition-transform duration-200 hover:-translate-y-0.5"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Get in touch
        </a>
        <a
          href="/hire"
          class="inline-flex items-center rounded-full border border-black/15 dark:border-white/20 px-5 py-2.5 text-sm font-semibold text-black dark:text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-black/5 dark:hover:bg-white/5"
        >
          Hire me
        </a>
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-black/15 dark:border-white/20 px-5 py-2.5 text-sm font-semibold text-black dark:text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-black/5 dark:hover:bg-white/5"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>
