---
import type { CollectionEntry } from "astro:content";
import { dateRange } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"work">;
  compact?: boolean;
  isLast?: boolean;
};

const { entry, compact = false, isLast = false } = Astro.props;

function normalizeLogoPath(path: string): string {
  if (path.startsWith("http://") || path.startsWith("https://")) return path;
  if (path.startsWith("/")) return path;
  return `/work/${path}`;
}

const logoSrc = entry.data.logo ? normalizeLogoPath(entry.data.logo) : null;
const isCurrent = entry.data.dateEnd === "Current";

const startLabel = entry.data.dateStart.toLocaleDateString("en-US", {
  month: "short",
  year: "numeric",
});

const dateLabel = isCurrent
  ? `since ${startLabel}`
  : dateRange(entry.data.dateStart, entry.data.dateEnd);
---

<!-- not-prose: avoids global article { prose } styles that break layout -->
<div class="not-prose relative flex gap-4 items-stretch">
  <!-- Timeline: circle + connector line -->
  <div class="relative shrink-0 w-10 self-stretch">
    <div
      class="relative z-10 w-10 h-10 rounded-full bg-white dark:bg-gray-950 ring-1 ring-black/10 dark:ring-white/15 flex items-center justify-center overflow-hidden"
    >
      {logoSrc ? (
        <img
          src={logoSrc}
          alt=""
          class="w-6 h-6 object-contain"
          loading="lazy"
        />
      ) : (
        <span class="text-xs font-semibold text-gray-400">
          {entry.data.company.charAt(0)}
        </span>
      )}
    </div>
    {!isLast && (
      <div
        class="absolute left-1/2 top-10 -translate-x-1/2 w-px bottom-0 bg-black/10 dark:bg-white/15"
        aria-hidden="true"
      />
    )}
  </div>

  <!-- Content: single left-aligned column -->
  <div class:list={["flex-1 min-w-0 text-left", !isLast && "pb-8"]}>
    <p class="font-medium text-black dark:text-white leading-snug m-0">
      {entry.data.role}
    </p>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 m-0">
      {entry.data.company}
      <span class="text-gray-400 dark:text-gray-500"> · {dateLabel}</span>
    </p>

    {compact && entry.data.summary && (
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-2 leading-relaxed m-0">
        {entry.data.summary}
      </p>
    )}

    {!compact && (
      <div class="prose prose-sm dark:prose-invert max-w-none mt-3 text-gray-600 dark:text-gray-400">
        <slot />
      </div>
    )}
  </div>
</div>
