---
import HeroBadge from "@components/HeroBadge.astro";

const isAvailable = true;
const status = isAvailable ? "Freelance" : "Unavailable";
const statusColor = isAvailable ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400";
const dotColor = isAvailable ? "bg-green-500" : "bg-red-500";
---

{isAvailable ? (
  <HeroBadge href="/hire" aria-label="Available for freelance work">
    <span class={`h-2 w-2 rounded-full ${dotColor} animate-pulse shrink-0`} aria-hidden="true"></span>
    <span class={statusColor}>{status}</span>
  </HeroBadge>
) : (
  <HeroBadge aria-label="Currently unavailable">
    <span class={`h-2 w-2 rounded-full ${dotColor} shrink-0`} aria-hidden="true"></span>
    <span class={statusColor}>{status}</span>
  </HeroBadge>
)}
