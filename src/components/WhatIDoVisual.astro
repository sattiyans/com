---
type Props = {
  variant: "saas" | "genai" | "payments" | "freelance" | "product" | "dashboard";
};

const { variant } = Astro.props;
---

<div class:list={["wiv", `wiv--${variant}`]} aria-hidden="true">
  {variant === "saas" && (
    <div class="wiv-stage">
      <div class="wiv-grid-bg"></div>
      {[0, 1, 2].map((i) => (
        <div class="ws-layer" style={`--i:${i}`}>
          <span class="ws-dot"></span>
          <span class="ws-bar"></span>
          <span class="ws-bar short"></span>
        </div>
      ))}
      <svg class="ws-flow" viewBox="0 0 120 60" preserveAspectRatio="none">
        <path d="M20 30 C45 30 55 18 60 18 C65 18 75 30 100 30" />
      </svg>
      {[0, 1].map((i) => (
        <span class="ws-packet" style={`--d:${i * 1.1}s`}></span>
      ))}
    </div>
  )}

  {variant === "genai" && (
    <div class="wiv-stage">
      <div class="wg-core">
        <span class="wg-ring"></span>
        <span class="wg-core-dot"></span>
      </div>
      <div class="wg-orbit-ring">
        {[0, 1, 2, 3].map((i) => (
          <span class="wg-orbit" style={`--i:${i}`}></span>
        ))}
      </div>
      <div class="wg-node wg-node--a"></div>
      <div class="wg-node wg-node--b"></div>
      <div class="wg-node wg-node--c"></div>
      <svg class="wg-link" viewBox="0 0 120 60" preserveAspectRatio="none">
        <path d="M30 30 L60 30 L90 30" />
      </svg>
      {[0, 1, 2].map((i) => (
        <span class="wg-spark" style={`--d:${i * 0.45}s`}></span>
      ))}
    </div>
  )}

  {variant === "payments" && (
    <div class="wiv-stage">
      <div class="wp-api">{`{ }`}</div>
      <svg class="wp-path" viewBox="0 0 120 60" preserveAspectRatio="none">
        <path d="M28 30 H92" stroke-dasharray="4 4" />
      </svg>
      <span class="wp-dot"></span>
      <div class="wp-card">
        <span class="wp-chip"></span>
        <span class="wp-line"></span>
      </div>
      <div class="wp-check">
        <svg viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" fill="currentColor" />
          <path d="M7.5 12.5l3 3 6-6.5" stroke="#0e0e10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
    </div>
  )}

  {variant === "freelance" && (
    <div class="wiv-stage">
      {[0, 1, 2].map((i) => (
        <div class="wf-step" style={`--s:${i}`}>
          <span class="wf-marker"></span>
        </div>
      ))}
      <div class="wf-track"></div>
      <div class="wf-doc">
        <span></span><span></span><span class="short"></span>
      </div>
      <div class="wf-ship">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M4 16l8-10 8 10H4z" fill="currentColor" />
          <path d="M9 16v3h6v-3" stroke="#0e0e10" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </div>
    </div>
  )}

  {variant === "product" && (
    <div class="wiv-stage">
      <div class="wpr-ui">
        <span class="wpr-ui-bar"></span>
        {[0, 1, 2].map((i) => (
          <span class="wpr-ui-line" style={`--d:${i * 0.2}s`}></span>
        ))}
      </div>
      <svg class="wpr-arrow" viewBox="0 0 24 24" fill="none">
        <path d="M4 12h15m0 0l-5-5m5 5l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <div class="wpr-api">
        <span class="wpr-brace">{`{ }`}</span>
        {[0, 1].map((i) => (
          <span class="wpr-code" style={`--d:${i * 0.35}s`}></span>
        ))}
      </div>
    </div>
  )}

  {variant === "dashboard" && (
    <div class="wiv-stage">
      <div class="wdb-chart">
        {[0.45, 0.75, 0.55, 0.9, 0.65].map((h, i) => (
          <span class="wdb-bar" style={`--h:${h};--d:${i * 0.15}s`}></span>
        ))}
      </div>
      <div class="wdb-panel">
        {[0, 1, 2].map((i) => (
          <div class="wdb-row" style={`--d:${i * 0.25}s`}>
            <span class="wdb-dot"></span>
            <span class="wdb-line"></span>
          </div>
        ))}
      </div>
    </div>
  )}
</div>

<style>
  .wiv {
    position: relative;
    width: 100%;
    height: 5rem;
    overflow: hidden;
    background: radial-gradient(130% 130% at 20% 0%, #26262b 0%, #161618 58%, #0d0d0f 100%);
    color: #fafafa;
  }

  .wiv-stage {
    position: absolute;
    inset: 0;
  }

  /* ── SaaS: layered services + data packets ── */
  .wiv-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgb(255 255 255 / 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgb(255 255 255 / 0.05) 1px, transparent 1px);
    background-size: 18px 18px;
    mask-image: radial-gradient(circle at 50% 50%, #000 35%, transparent 85%);
  }

  .ws-layer {
    position: absolute;
    left: calc(14% + var(--i) * 22%);
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    padding: 0.35rem 0.4rem;
    border-radius: 0.4rem;
    background: rgb(255 255 255 / 0.92);
    box-shadow: 0 4px 12px rgb(0 0 0 / 0.35);
    animation: ws-float 3.2s ease-in-out infinite both;
    animation-delay: calc(var(--i) * 0.35s);
  }

  @keyframes ws-float {
    0%, 100% { transform: translateY(-50%); }
    50% { transform: translateY(calc(-50% - 4px)); }
  }

  .ws-dot {
    display: block;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: #18181b;
    margin-bottom: 0.25rem;
    animation: ws-pulse 2s ease-in-out infinite both;
    animation-delay: calc(var(--i) * 0.25s);
  }

  @keyframes ws-pulse {
    0%, 100% { opacity: 0.45; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1); }
  }

  .ws-bar {
    display: block;
    height: 0.18rem;
    border-radius: 9999px;
    background: #a1a1aa;
    margin-bottom: 0.18rem;
  }

  .ws-bar.short { width: 65%; }

  .ws-flow {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .ws-flow path {
    fill: none;
    stroke: rgb(255 255 255 / 0.22);
    stroke-width: 1.5;
  }

  .ws-packet {
    position: absolute;
    top: 50%;
    left: 18%;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: #fafafa;
    box-shadow: 0 0 0 3px rgb(255 255 255 / 0.12);
    animation: ws-travel 2.2s ease-in-out infinite both;
    animation-delay: var(--d);
  }

  @keyframes ws-travel {
    0% { left: 18%; opacity: 0; transform: translateY(-50%) scale(0.6); }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { left: 78%; opacity: 0; transform: translateY(-50%) scale(0.85); }
  }

  /* ── GenAI: core + orbit + workflow sparks ── */
  .wg-core {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 2rem;
    height: 2rem;
  }

  .wg-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgb(255 255 255 / 0.25);
    animation: wg-spin 8s linear infinite;
  }

  @keyframes wg-spin {
    to { transform: rotate(360deg); }
  }

  .wg-core-dot {
    position: absolute;
    inset: 0.45rem;
    border-radius: 50%;
    background: #fafafa;
    animation: ws-pulse 2.4s ease-in-out infinite;
  }

  .wg-orbit-ring {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0;
    height: 0;
    animation: wg-spin 7s linear infinite;
  }

  .wg-orbit {
    position: absolute;
    width: 0.35rem;
    height: 0.35rem;
    margin: -0.175rem 0 0 -0.175rem;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.75);
    transform: rotate(calc(var(--i) * 90deg)) translateX(1.35rem);
  }

  .wg-node {
    position: absolute;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 0.15rem;
    background: rgb(255 255 255 / 0.18);
    border: 1px solid rgb(255 255 255 / 0.28);
  }

  .wg-node--a { left: 12%; top: 28%; }
  .wg-node--b { right: 12%; top: 28%; }
  .wg-node--c { right: 18%; bottom: 22%; }

  .wg-link {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .wg-link path {
    fill: none;
    stroke: rgb(255 255 255 / 0.18);
    stroke-width: 1.25;
    stroke-dasharray: 3 4;
    animation: wg-dash 1.4s linear infinite;
  }

  @keyframes wg-dash {
    to { stroke-dashoffset: -14; }
  }

  .wg-spark {
    position: absolute;
    width: 0.25rem;
    height: 0.25rem;
    border-radius: 50%;
    background: #fafafa;
    left: calc(22% + var(--d) * 40%);
    top: 22%;
    opacity: 0;
    animation: wg-spark 2.8s ease-in-out infinite both;
    animation-delay: var(--d);
  }

  @keyframes wg-spark {
    0%, 100% { opacity: 0; transform: translateY(0); }
    40%, 60% { opacity: 0.9; transform: translateY(-6px); }
  }

  /* ── Payments: API → transaction → card ── */
  .wp-api {
    position: absolute;
    left: 10%;
    top: 50%;
    transform: translateY(-50%);
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: rgb(255 255 255 / 0.75);
    animation: ws-pulse 2.5s ease-in-out infinite;
  }

  .wp-path {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .wp-path path {
    fill: none;
    stroke: rgb(255 255 255 / 0.28);
    stroke-width: 1.5;
    animation: wg-dash 1.2s linear infinite;
  }

  .wp-dot {
    position: absolute;
    top: 50%;
    left: 22%;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: #fafafa;
    transform: translateY(-50%);
    animation: wp-move 2.4s ease-in-out infinite;
  }

  @keyframes wp-move {
    0% { left: 22%; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: 72%; opacity: 0; }
  }

  .wp-card {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
    width: 2.5rem;
    padding: 0.35rem 0.4rem;
    border-radius: 0.35rem;
    background: #fafafa;
    box-shadow: 0 4px 10px rgb(0 0 0 / 0.35);
  }

  .wp-chip {
    display: block;
    width: 0.65rem;
    height: 0.45rem;
    border-radius: 0.15rem;
    background: #18181b;
    margin-bottom: 0.3rem;
  }

  .wp-line {
    display: block;
    height: 0.15rem;
    border-radius: 9999px;
    background: #d4d4d8;
  }

  .wp-check {
    position: absolute;
    right: 22%;
    top: 18%;
    width: 1rem;
    height: 1rem;
    color: #e4e4e7;
    animation: ws-pulse 2.4s ease-in-out infinite 0.6s;
  }

  .wp-check svg { width: 100%; height: 100%; }

  /* ── Freelance: discovery → build → ship ── */
  .wf-track {
    position: absolute;
    left: 12%;
    right: 12%;
    top: 54%;
    height: 2px;
    border-radius: 2px;
    background: rgb(255 255 255 / 0.2);
  }

  .wf-step {
    position: absolute;
    top: 54%;
    left: calc(16% + var(--s) * 28%);
    transform: translate(-50%, -50%);
    z-index: 1;
  }

  .wf-marker {
    display: block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.25);
    animation: wf-step 2.8s ease-in-out infinite both;
    animation-delay: calc(var(--s) * 0.45s);
  }

  @keyframes wf-step {
    0%, 100% { background: rgb(255 255 255 / 0.25); transform: scale(0.85); }
    50% { background: #fafafa; transform: scale(1.15); }
  }

  .wf-doc {
    position: absolute;
    left: 14%;
    top: 22%;
    width: 1.35rem;
    padding: 0.25rem;
    border-radius: 0.25rem;
    background: #fafafa;
    box-shadow: 0 3px 8px rgb(0 0 0 / 0.3);
    animation: ws-float 3s ease-in-out infinite;
  }

  .wf-doc span {
    display: block;
    height: 0.12rem;
    border-radius: 9999px;
    background: #a1a1aa;
    margin-bottom: 0.15rem;
  }

  .wf-doc span.short { width: 60%; }

  .wf-ship {
    position: absolute;
    right: 12%;
    top: 18%;
    width: 1.35rem;
    height: 1.35rem;
    color: #fafafa;
    animation: wf-ship 3.2s ease-in-out infinite;
  }

  .wf-ship svg { width: 100%; height: 100%; filter: drop-shadow(0 3px 6px rgb(0 0 0 / 0.35)); }

  @keyframes wf-ship {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  /* ── Product: UI ↔ API full-stack ── */
  .wpr-ui {
    position: absolute;
    left: 10%;
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    padding: 0.35rem 0.4rem;
    border-radius: 0.35rem;
    background: #fafafa;
    box-shadow: 0 4px 10px rgb(0 0 0 / 0.35);
    animation: ws-float 3.2s ease-in-out infinite;
  }

  .wpr-ui-bar {
    display: block;
    height: 0.22rem;
    border-radius: 9999px;
    background: #52525b;
    margin-bottom: 0.3rem;
  }

  .wpr-ui-line {
    display: block;
    height: 0.14rem;
    border-radius: 9999px;
    background: #d4d4d8;
    margin-bottom: 0.16rem;
    transform-origin: left;
    animation: wpr-grow 2.6s ease-in-out infinite both;
    animation-delay: var(--d);
  }

  @keyframes wpr-grow {
    0%, 100% { transform: scaleX(0.55); opacity: 0.55; }
    50% { transform: scaleX(1); opacity: 1; }
  }

  .wpr-arrow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 1.25rem;
    height: 1.25rem;
    color: rgb(255 255 255 / 0.7);
    transform: translate(-50%, -50%);
    animation: wpr-arrow 2s ease-in-out infinite;
  }

  @keyframes wpr-arrow {
    0%, 100% { transform: translate(-58%, -50%); opacity: 0.5; }
    50% { transform: translate(-42%, -50%); opacity: 1; }
  }

  .wpr-api {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    padding: 0.35rem 0.4rem;
    border-radius: 0.35rem;
    background: rgb(255 255 255 / 0.1);
    border: 1px solid rgb(255 255 255 / 0.18);
  }

  .wpr-brace {
    display: block;
    font-family: ui-monospace, monospace;
    font-size: 0.625rem;
    font-weight: 700;
    color: rgb(255 255 255 / 0.75);
    margin-bottom: 0.25rem;
  }

  .wpr-code {
    display: block;
    height: 0.14rem;
    border-radius: 9999px;
    background: rgb(255 255 255 / 0.35);
    margin-bottom: 0.16rem;
    animation: ws-pulse 2.4s ease-in-out infinite both;
    animation-delay: var(--d);
  }

  /* ── Dashboard: charts + table rows ── */
  .wdb-chart {
    position: absolute;
    left: 10%;
    bottom: 18%;
    display: flex;
    align-items: flex-end;
    gap: 0.25rem;
    height: 2.25rem;
  }

  .wdb-bar {
    width: 0.45rem;
    border-radius: 0.15rem 0.15rem 0 0;
    background: linear-gradient(to top, rgb(255 255 255 / 0.35), rgb(255 255 255 / 0.95));
    height: calc(var(--h) * 100%);
    transform-origin: bottom;
    animation: wdb-grow 2.8s ease-in-out infinite both;
    animation-delay: var(--d);
  }

  @keyframes wdb-grow {
    0%, 100% { transform: scaleY(0.5); opacity: 0.55; }
    50% { transform: scaleY(1); opacity: 1; }
  }

  .wdb-panel {
    position: absolute;
    right: 10%;
    top: 22%;
    width: 3.25rem;
    padding: 0.35rem 0.4rem;
    border-radius: 0.35rem;
    background: #fafafa;
    box-shadow: 0 4px 10px rgb(0 0 0 / 0.35);
  }

  .wdb-row {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 0.22rem;
    opacity: 0;
    animation: wdb-row 3s ease-in-out infinite both;
    animation-delay: var(--d);
  }

  @keyframes wdb-row {
    0%, 10% { opacity: 0; transform: translateX(-3px); }
    22%, 80% { opacity: 1; transform: translateX(0); }
    100% { opacity: 1; }
  }

  .wdb-dot {
    flex-shrink: 0;
    width: 0.28rem;
    height: 0.28rem;
    border-radius: 50%;
    background: #18181b;
  }

  .wdb-line {
    flex: 1;
    height: 0.14rem;
    border-radius: 9999px;
    background: #d4d4d8;
  }

  @media (prefers-reduced-motion: reduce) {
    .wiv * {
      animation: none !important;
    }
  }
</style>
