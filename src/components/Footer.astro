---

<footer class="mt-16 border-t border-black/10 dark:border-white/10">
  <Container>
    <div class="py-10">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
        <!-- Brand -->
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-black text-sm font-bold text-white dark:bg-white dark:text-black">
              S
            </span>
            <span class="font-semibold text-black dark:text-white">{SITE.NAME}</span>
          </div>
          <p class="max-w-xs text-sm leading-relaxed text-gray-600 dark:text-gray-400">
            Technology Lead at G6 Labs Asia and founder of Dotkod Solutions —
            building scalable SaaS platforms, GenAI automation, and digital products.
          </p>
          <a
            href={`mailto:${SITE.EMAIL}`}
            class="inline-flex items-center gap-2 text-sm font-medium text-black hover:underline dark:text-white"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {SITE.EMAIL}
          </a>
        </div>

        <!-- Explore -->
        <div class="space-y-3">
          <h4 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-500">
            Explore
          </h4>
          <div class="flex flex-col gap-2">
            {navLinks.map((link) => (
              <Link
                href={link.href}
                underline={false}
                class="text-sm text-gray-600 transition-colors duration-200 hover:text-black dark:text-gray-400 dark:hover:text-white"
              >
                {link.label}
              </Link>
            ))}
          </div>
        </div>

        <!-- More -->
        <div class="space-y-3">
          <h4 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-500">
            More
          </h4>
          <div class="flex flex-col gap-2">
            {moreLinks.map((link) => (
              <Link
                href={link.href}
                underline={false}
                class="text-sm text-gray-600 transition-colors duration-200 hover:text-black dark:text-gray-400 dark:hover:text-white"
              >
                {link.label}
              </Link>
            ))}
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-black/5 pt-6 dark:border-white/5 sm:flex-row">
        <p class="text-sm text-gray-500 dark:text-gray-500">
          &copy; {year} {SITE.NAME}. All rights reserved.
        </p>

        <div class="flex items-center gap-1.5">
          {SOCIALS.filter((s) => socialIcon[s.NAME]).map((social) => (
            <Link
              href={social.HREF}
              external
              underline={false}
              aria-label={`${SITE.NAME} on ${social.NAME}`}
              class="flex h-8 w-8 items-center justify-center rounded-lg text-gray-500 transition-colors duration-200 hover:bg-black/5 hover:text-black dark:text-gray-400 dark:hover:bg-white/10 dark:hover:text-white"
            >
              <svg class="h-[18px] w-[18px]" fill="currentColor" viewBox="0 0 24 24">
                <path d={socialIcon[social.NAME]} />
              </svg>
            </Link>
          ))}
          <Link
            href={`mailto:${SITE.EMAIL}`}
            underline={false}
            aria-label={`Email ${SITE.NAME}`}
            class="flex h-8 w-8 items-center justify-center rounded-lg text-gray-500 transition-colors duration-200 hover:bg-black/5 hover:text-black dark:text-gray-400 dark:hover:bg-white/10 dark:hover:text-white"
          >
            <svg class="h-[18px] w-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </Link>
        </div>
      </div>
    </div>
  </Container>
</footer>
