---
type Props = {
  variant: string;
};

const { variant } = Astro.props;

const known = ["gboost", "gsendr", "lapar-la", "femo", "invested"];
const scene = known.includes(variant) ? variant : "default";
---

<div class:list={["pv", `pv--${scene}`]} aria-hidden="true">
  {scene === "gboost" && (
    <div class="pv-stage">
      <!-- Local SEO: map pin + reviews + analytics -->
      <div class="gb-grid"></div>
      <div class="gb-pin">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 22s7-6.16 7-12A7 7 0 0 0 5 10c0 5.84 7 12 7 12Z" fill="currentColor" />
          <circle cx="12" cy="10" r="2.6" fill="#0e0e10" />
        </svg>
        <span class="gb-pulse"></span>
      </div>
      <div class="gb-stars">
        {[0, 1, 2, 3, 4].map((i) => (
          <svg viewBox="0 0 24 24" style={`--d:${i * 0.18}s`}>
            <path d="M12 2l2.9 6.2 6.6.7-4.9 4.5 1.4 6.6L12 17.7 6 20.5l1.4-6.6L2.5 8.9l6.6-.7L12 2z" />
          </svg>
        ))}
      </div>
      <div class="gb-bars">
        {[0.45, 0.7, 0.55, 0.9, 0.65, 1].map((h, i) => (
          <span style={`--h:${h};--d:${i * 0.12}s`}></span>
        ))}
      </div>
      <div class="gb-chip">AI</div>
    </div>
  )}

  {scene === "gsendr" && (
    <div class="pv-stage">
      <!-- Email infra: hub sends envelopes to nodes + verified shield -->
      <svg class="gs-lines" viewBox="0 0 200 120" preserveAspectRatio="none">
        <path d="M100 60 C140 30 160 30 184 24" />
        <path d="M100 60 C140 60 160 64 186 60" />
        <path d="M100 60 C140 90 160 92 184 98" />
      </svg>
      <div class="gs-hub">
        <svg viewBox="0 0 24 24" fill="none">
          <rect x="2.5" y="5" width="19" height="14" rx="2.5" fill="currentColor" />
          <path d="M3.5 7l8.5 6 8.5-6" stroke="#fafafa" stroke-width="1.6" fill="none" stroke-linecap="round" />
        </svg>
      </div>
      {[0, 1, 2].map((i) => (
        <span class="gs-envelope" style={`--t:${i};--d:${i * 0.5}s`}>
          <svg viewBox="0 0 24 24" fill="none">
            <rect x="3" y="6" width="18" height="12" rx="2" fill="#e7e7ea" />
            <path d="M4 8l8 5 8-5" stroke="#18181b" stroke-width="1.6" fill="none" stroke-linecap="round" />
          </svg>
        </span>
      ))}
      {[0, 1, 2].map((i) => (
        <span class="gs-node" style={`--n:${i}`}></span>
      ))}
      <div class="gs-shield">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5l8-3z" fill="currentColor" />
          <path d="M8.5 12l2.3 2.3L15.5 9.8" stroke="#0e0e10" stroke-width="1.7" fill="none" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
    </div>
  )}

  {scene === "lapar-la" && (
    <div class="pv-stage">
      <!-- Recipe platform: social post -> structured recipe -->
      <div class="ll-post">
        <div class="ll-post-img">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M8 5v14l11-7L8 5z" fill="#fafafa" />
          </svg>
        </div>
        <div class="ll-post-bar"></div>
        <div class="ll-post-bar short"></div>
      </div>
      <svg class="ll-arrow" viewBox="0 0 24 24" fill="none">
        <path d="M4 12h15m0 0l-5-5m5 5l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <div class="ll-card">
        <div class="ll-card-title"></div>
        {[0, 1, 2, 3].map((i) => (
          <div class="ll-row" style={`--d:${i * 0.18}s`}>
            <span class="ll-check">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M5 12l5 5L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <span class="ll-line"></span>
          </div>
        ))}
      </div>
      {[0, 1, 2, 3, 4].map((i) => (
        <span class="ll-spark" style={`--i:${i}`}></span>
      ))}
    </div>
  )}

  {scene === "femo" && (
    <div class="pv-stage">
      <!-- Influencer marketing: brand + creator connect, chat, payment -->
      <div class="fm-avatar fm-brand">
        <svg viewBox="0 0 24 24" fill="none">
          <rect x="4" y="4" width="16" height="16" rx="4" fill="currentColor" />
          <path d="M9 14l2.5-3 2 2.4L15.5 10" stroke="#fafafa" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <div class="fm-avatar fm-creator">
        <svg viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="9" r="3.4" fill="currentColor" />
          <path d="M5.5 19c.8-3.4 3.3-5 6.5-5s5.7 1.6 6.5 5" fill="currentColor" />
        </svg>
      </div>
      <svg class="fm-link" viewBox="0 0 200 120" preserveAspectRatio="none">
        <path d="M52 60 C90 60 110 60 148 60" />
      </svg>
      <span class="fm-bubble fm-b1"></span>
      <span class="fm-bubble fm-b2"></span>
      <div class="fm-heart">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 21s-7-4.5-9.5-9C1 9 2.5 5.5 6 5.5c2 0 3.2 1.1 4 2.3.8-1.2 2-2.3 4-2.3 3.5 0 5 3.5 3.5 6.5C19 16.5 12 21 12 21z" />
        </svg>
      </div>
      <div class="fm-coin">$</div>
    </div>
  )}

  {scene === "invested" && (
    <div class="pv-stage">
      <!-- Backend API + admin workflow: docs move through pipeline stages -->
      <div class="iv-pipeline">
        {[0, 1, 2].map((s) => (
          <div class="iv-stage" style={`--s:${s}`}>
            <span class="iv-dot"></span>
          </div>
        ))}
        <div class="iv-track"></div>
      </div>
      {[0, 1].map((i) => (
        <div class="iv-doc" style={`--d:${i * 1.6}s`}>
          <span></span><span></span><span class="short"></span>
        </div>
      ))}
      <div class="iv-check">
        <svg viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" fill="currentColor" />
          <path d="M7.5 12.5l3 3 6-6.5" stroke="#0e0e10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <div class="iv-api">{`{ }`}</div>
    </div>
  )}

  {scene === "default" && (
    <div class="pv-stage">
      <div class="df-brackets">&lt;/&gt;</div>
      {[0, 1, 2, 3].map((i) => (
        <span class="df-shape" style={`--i:${i}`}></span>
      ))}
    </div>
  )}
</div>

<style>
  .pv {
    position: absolute;
    inset: 0;
    overflow: hidden;
    color: #fafafa;
  }

  .pv-stage {
    position: absolute;
    inset: 0;
  }

  /* Unified minimal neutral backdrop for every project */
  .pv--gboost,
  .pv--gsendr,
  .pv--lapar-la,
  .pv--femo,
  .pv--invested,
  .pv--default {
    background: radial-gradient(130% 130% at 25% 12%, #26262b 0%, #161618 58%, #0d0d0f 100%);
  }

  /* ============ GBOOST ============ */
  .gb-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgb(255 255 255 / 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgb(255 255 255 / 0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(circle at 30% 40%, #000 30%, transparent 75%);
  }
  .gb-pin {
    position: absolute;
    left: 26%;
    top: 38%;
    width: 46px;
    height: 46px;
    color: #fafafa;
    transform: translate(-50%, -50%);
    animation: gb-bob 3s ease-in-out infinite;
  }
  .gb-pin svg { width: 100%; height: 100%; filter: drop-shadow(0 6px 10px rgb(0 0 0 / 0.4)); }
  .gb-pulse {
    position: absolute;
    left: 50%;
    bottom: -6px;
    width: 30px;
    height: 10px;
    transform: translateX(-50%);
    border-radius: 50%;
    background: rgb(0 0 0 / 0.4);
    animation: gb-shadow 3s ease-in-out infinite;
  }
  @keyframes gb-bob {
    0%, 100% { transform: translate(-50%, -50%); }
    50% { transform: translate(-50%, -62%); }
  }
  @keyframes gb-shadow {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.4; }
    50% { transform: translateX(-50%) scale(0.7); opacity: 0.25; }
  }
  .gb-stars {
    position: absolute;
    right: 7%;
    top: 24%;
    display: flex;
    gap: 4px;
  }
  .gb-stars svg {
    width: 18px;
    height: 18px;
    fill: rgb(255 255 255 / 0.25);
    animation: gb-star 3s ease-in-out infinite both;
    animation-delay: var(--d);
  }
  @keyframes gb-star {
    0%, 60%, 100% { fill: rgb(255 255 255 / 0.25); transform: scale(1); }
    30% { fill: #fafafa; transform: scale(1.18); }
  }
  .gb-bars {
    position: absolute;
    right: 8%;
    bottom: 16%;
    display: flex;
    align-items: flex-end;
    gap: 6px;
    height: 64px;
  }
  .gb-bars span {
    width: 12px;
    border-radius: 4px 4px 0 0;
    background: linear-gradient(to top, rgb(255 255 255 / 0.4), rgb(255 255 255 / 0.95));
    height: calc(var(--h) * 100%);
    transform-origin: bottom;
    animation: gb-grow 2.6s ease-in-out infinite both;
    animation-delay: var(--d);
  }
  @keyframes gb-grow {
    0%, 100% { transform: scaleY(0.55); opacity: 0.6; }
    50% { transform: scaleY(1); opacity: 1; }
  }
  .gb-chip {
    position: absolute;
    left: 16%;
    bottom: 20%;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #18181b;
    background: #fafafa;
    padding: 3px 9px;
    border-radius: 9999px;
    box-shadow: 0 4px 12px rgb(0 0 0 / 0.3);
    animation: gb-bob 3s ease-in-out infinite 0.6s;
  }

  /* ============ GSENDR ============ */
  .gs-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .gs-lines path {
    fill: none;
    stroke: rgb(255 255 255 / 0.28);
    stroke-width: 1.5;
    stroke-dasharray: 4 5;
    animation: gs-dash 1.2s linear infinite;
  }
  @keyframes gs-dash { to { stroke-dashoffset: -18; } }
  .gs-hub {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 56px;
    height: 56px;
    transform: translate(-50%, -50%);
    color: #18181b;
    background: #fafafa;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 20px rgb(0 0 0 / 0.35);
    animation: gs-hub 3s ease-in-out infinite;
  }
  .gs-hub svg { width: 30px; height: 30px; }
  @keyframes gs-hub {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -50%) scale(1.05); }
  }
  .gs-envelope {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 22px;
    height: 22px;
    transform: translate(-50%, -50%);
    opacity: 0;
    animation: gs-fly 2.4s ease-in infinite both;
    animation-delay: var(--d);
  }
  .gs-envelope svg { width: 100%; height: 100%; filter: drop-shadow(0 3px 6px rgb(0 0 0 / 0.4)); }
  .gs-envelope:nth-child(3) { --ty: -54px; }
  .gs-envelope:nth-child(4) { --ty: 0px; }
  .gs-envelope:nth-child(5) { --ty: 54px; }
  @keyframes gs-fly {
    0% { transform: translate(-50%, -50%) scale(0.6); opacity: 0; }
    25% { opacity: 1; }
    100% { transform: translate(calc(-50% + 86px), calc(-50% + var(--ty, 0px))) scale(0.85); opacity: 0; }
  }
  .gs-node {
    position: absolute;
    right: 6%;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.85);
    box-shadow: 0 0 0 4px rgb(255 255 255 / 0.14);
  }
  .gs-node:nth-of-type(1) { top: 20%; }
  .gs-node:nth-of-type(2) { top: 49%; }
  .gs-node:nth-of-type(3) { top: 78%; }
  .gs-shield {
    position: absolute;
    left: 12%;
    bottom: 18%;
    width: 30px;
    height: 30px;
    color: #e7e7ea;
    animation: gs-hub 3s ease-in-out infinite 0.4s;
  }
  .gs-shield svg { width: 100%; height: 100%; filter: drop-shadow(0 4px 8px rgb(0 0 0 / 0.35)); }

  /* ============ LAPAR.LA ============ */
  .ll-post {
    position: absolute;
    left: 12%;
    top: 50%;
    transform: translateY(-50%);
    width: 92px;
    background: #fafafa;
    border-radius: 12px;
    padding: 8px;
    box-shadow: 0 10px 24px rgb(0 0 0 / 0.32);
    animation: ll-float 3.4s ease-in-out infinite;
  }
  .ll-post-img {
    aspect-ratio: 1;
    border-radius: 8px;
    background: linear-gradient(135deg, #3f3f46, #18181b);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 7px;
  }
  .ll-post-img svg { width: 22px; height: 22px; }
  .ll-post-bar { height: 5px; border-radius: 3px; background: #d4d4d8; }
  .ll-post-bar.short { width: 60%; margin-top: 4px; }
  @keyframes ll-float {
    0%, 100% { transform: translateY(-50%); }
    50% { transform: translateY(-58%); }
  }
  .ll-arrow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 30px;
    height: 30px;
    color: #fafafa;
    transform: translate(-50%, -50%);
    animation: ll-arrow 1.8s ease-in-out infinite;
  }
  @keyframes ll-arrow {
    0%, 100% { transform: translate(-58%, -50%); opacity: 0.6; }
    50% { transform: translate(-42%, -50%); opacity: 1; }
  }
  .ll-card {
    position: absolute;
    right: 11%;
    top: 50%;
    transform: translateY(-50%);
    width: 116px;
    background: #fafafa;
    border-radius: 12px;
    padding: 11px;
    box-shadow: 0 10px 24px rgb(0 0 0 / 0.32);
    animation: ll-float 3.4s ease-in-out infinite 0.5s;
  }
  .ll-card-title {
    width: 66%;
    height: 7px;
    border-radius: 4px;
    background: #52525b;
    margin-bottom: 9px;
  }
  .ll-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 6px;
    opacity: 0;
    animation: ll-row 3.4s ease-in-out infinite both;
    animation-delay: var(--d);
  }
  @keyframes ll-row {
    0%, 12% { opacity: 0; transform: translateX(-4px); }
    24%, 80% { opacity: 1; transform: translateX(0); }
    100% { opacity: 1; }
  }
  .ll-check {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #e4e4e7;
    color: #18181b;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ll-check svg { width: 9px; height: 9px; }
  .ll-line { flex: 1; height: 5px; border-radius: 3px; background: #d4d4d8; }
  .ll-spark {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.8);
    top: calc(20% + (var(--i) * 14%));
    left: calc(44% + (var(--i) * 4%));
    animation: ll-spark 2.8s ease-in-out infinite both;
    animation-delay: calc(var(--i) * 0.3s);
  }
  @keyframes ll-spark {
    0%, 100% { transform: translateY(0) scale(0.6); opacity: 0; }
    50% { transform: translateY(-14px) scale(1); opacity: 0.85; }
  }

  /* ============ FEMO ============ */
  .fm-avatar {
    position: absolute;
    top: 50%;
    width: 50px;
    height: 50px;
    border-radius: 16px;
    background: #fafafa;
    color: #18181b;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateY(-50%);
    box-shadow: 0 8px 18px rgb(0 0 0 / 0.32);
  }
  .fm-avatar svg { width: 30px; height: 30px; }
  .fm-brand { left: 18%; animation: fm-bobL 3s ease-in-out infinite; }
  .fm-creator { right: 18%; border-radius: 50%; animation: fm-bobR 3s ease-in-out infinite 0.4s; }
  @keyframes fm-bobL { 0%,100%{transform:translateY(-50%);} 50%{transform:translateY(-62%);} }
  @keyframes fm-bobR { 0%,100%{transform:translateY(-50%);} 50%{transform:translateY(-38%);} }
  .fm-link { position: absolute; inset: 0; width: 100%; height: 100%; }
  .fm-link path {
    fill: none;
    stroke: rgb(255 255 255 / 0.4);
    stroke-width: 2;
    stroke-dasharray: 5 6;
    animation: gs-dash 1s linear infinite;
  }
  .fm-bubble {
    position: absolute;
    top: 30%;
    width: 16px;
    height: 12px;
    border-radius: 8px;
    background: #fafafa;
    opacity: 0;
    animation: fm-bubble 2.6s ease-in-out infinite both;
  }
  .fm-b1 { left: 42%; animation-delay: 0s; }
  .fm-b2 { left: 52%; top: 64%; animation-delay: 0.8s; }
  @keyframes fm-bubble {
    0% { opacity: 0; transform: scale(0.5) translateY(6px); }
    30%, 70% { opacity: 1; transform: scale(1) translateY(0); }
    100% { opacity: 0; transform: scale(0.6) translateY(-6px); }
  }
  .fm-heart {
    position: absolute;
    left: 50%;
    top: 26%;
    width: 22px;
    height: 22px;
    color: #fafafa;
    transform: translateX(-50%);
    animation: fm-heart 2.2s ease-in-out infinite;
  }
  .fm-heart svg { width: 100%; height: 100%; }
  @keyframes fm-heart {
    0%, 100% { transform: translateX(-50%) scale(1); }
    50% { transform: translateX(-50%) scale(1.25); }
  }
  .fm-coin {
    position: absolute;
    left: 50%;
    bottom: 20%;
    transform: translateX(-50%);
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #e4e4e7;
    color: #18181b;
    font-weight: 800;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 14px rgb(0 0 0 / 0.32);
    animation: fm-coin 3s ease-in-out infinite;
  }
  @keyframes fm-coin {
    0%, 100% { transform: translateX(-50%) translateY(0) rotateY(0); }
    50% { transform: translateX(-50%) translateY(-8px) rotateY(180deg); }
  }

  /* ============ INVESTED ============ */
  .iv-pipeline {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 64%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .iv-track {
    position: absolute;
    left: 6px;
    right: 6px;
    top: 50%;
    height: 3px;
    border-radius: 3px;
    background: rgb(255 255 255 / 0.22);
    z-index: 0;
  }
  .iv-stage {
    position: relative;
    z-index: 1;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.16);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .iv-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #fafafa;
    animation: iv-pulse 2.4s ease-in-out infinite both;
    animation-delay: calc(var(--s) * 0.5s);
  }
  @keyframes iv-pulse {
    0%, 100% { transform: scale(0.7); opacity: 0.6; }
    50% { transform: scale(1.15); opacity: 1; }
  }
  .iv-doc {
    position: absolute;
    top: 50%;
    left: 18%;
    width: 30px;
    height: 38px;
    background: #fafafa;
    border-radius: 6px;
    padding: 6px 5px;
    box-shadow: 0 8px 16px rgb(0 0 0 / 0.3);
    animation: iv-move 3.2s ease-in-out infinite both;
    animation-delay: var(--d);
  }
  .iv-doc span {
    display: block;
    height: 3px;
    border-radius: 2px;
    background: #a1a1aa;
    margin-bottom: 4px;
  }
  .iv-doc span.short { width: 60%; }
  @keyframes iv-move {
    0% { left: 18%; top: 50%; transform: translateY(-50%) scale(0.85); opacity: 0; }
    15% { opacity: 1; }
    50% { left: 50%; transform: translateY(-50%) scale(1); }
    85% { opacity: 1; }
    100% { left: 82%; top: 50%; transform: translateY(-50%) scale(0.85); opacity: 0; }
  }
  .iv-check {
    position: absolute;
    right: 13%;
    top: 28%;
    width: 26px;
    height: 26px;
    color: #fafafa;
    animation: iv-pulse 2.4s ease-in-out infinite 1s;
  }
  .iv-check svg { width: 100%; height: 100%; filter: drop-shadow(0 4px 8px rgb(0 0 0 / 0.35)); }
  .iv-api {
    position: absolute;
    left: 12%;
    bottom: 18%;
    font-family: ui-monospace, monospace;
    font-size: 16px;
    font-weight: 700;
    color: rgb(255 255 255 / 0.8);
    letter-spacing: 0.1em;
    animation: iv-pulse 2.4s ease-in-out infinite 0.3s;
  }

  /* ============ DEFAULT ============ */
  .df-brackets {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    font-family: ui-monospace, monospace;
    font-size: 44px;
    font-weight: 700;
    color: #fafafa;
    opacity: 0.9;
    animation: gs-hub 3s ease-in-out infinite;
  }
