# Spotify API Configuration
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here

# Other environment variables (if needed)
# GITHUB_TOKEN=your_github_token_here

# OpenAI (Ask chatbot)
OPENAI_SECRET_KEY=your_openai_api_key_here

# Contact email delivery (Resend)
RESEND_API_KEY=your_resend_api_key_here
# Single recipient fallback
CONTACT_TO_EMAIL=hey@sattiyans.com
# Optional comma-separated recipients (overrides CONTACT_TO_EMAIL when set)
# CONTACT_TO_EMAILS=hey@sattiyans.com,another@email.com
# Sender identity configured in Resend (or use onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
